# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
wheels/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Data (tracked by DVC, not git)
data/raw/
data/processed/
*.parquet
*.csv
*.feather

# Model checkpoints (too large for git, >100MB)
checkpoints/
*.pth
*.onnx

# IMPORTANT: Allow outputs/ and *.pt results to sync!
# Only exclude large checkpoint files inside outputs
outputs/**/best.pt
outputs/**/last.pt
outputs/**/ema.pt

# W&B
wandb/

# DVC
/data/*.dvc

# Jupyter
.ipynb_checkpoints/

# Logs (allow output logs, exclude generic)
logs/

# Secrets
.env
*.key


# OICC transient artifacts
experiments/oicc_runs/*.output
*.egg-info/
.ipynb_checkpoints/
unpushed_changes.patch

# arXiv build artifacts (regenerate with make_arxiv.py)
paper/arxiv/build/

# campaign outputs + archived old outputs (local only)
results_campaign_*/
archive/
